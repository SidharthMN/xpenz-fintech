{
  "name": "xpenz",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:serve": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "main": "electron-main.cjs",
  "build": {
    "appId": "com.xpenz.desktop",
    "productName": "Xpenz",
    "directories": {
      "output": "dist_electron",
      "buildResources": "assets"
    },
    "files": [
      "dist/**",
      "electron-main.cjs",
      "electron-preload.cjs",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "zip"]
    },
    "mac": {
      "target": ["dmg", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  },
  "dependencies": {
    "chart.js": "^4.4.3",
    "firebase": "^11.10.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-icons": "^5.2.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^26.2.0",
    "electron-builder": "^24.6.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "wait-on": "^7.0.1",
    "vite": "^5.3.4"
  }
}
